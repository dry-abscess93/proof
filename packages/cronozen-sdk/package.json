{
  "name": "cronozen",
  "version": "0.2.0",
  "description": "Immutable decision evidence for AI and business operations — record, verify, export.",
  "license": "Apache-2.0",
  "author": "Cronozen <hello@cronozen.com>",
  "homepage": "https://github.com/cronozen/cronozen-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/cronozen/cronozen-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/cronozen/cronozen-sdk/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "cronozen",
    "proof",
    "decision",
    "evidence",
    "audit",
    "ai",
    "governance",
    "compliance",
    "hash-chain",
    "immutable"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
