{
  "name": "@cronozen/proof-api",
  "version": "0.1.0",
  "private": true,
  "description": "Cronozen Proof Cloud API — MVP",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "db:init": "tsx src/db/init.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cronozen/dpu-core": "file:../packages/dpu-core",
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.0.0",
    "googleapis": "^171.4.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
