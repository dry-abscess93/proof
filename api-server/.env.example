# Cronozen Proof API — Environment Variables

# Server
PORT=3200

# Database (SQLite path, default: ./data/proof.db)
DB_PATH=./data/proof.db

# Public URL (for verification links in JSON-LD export)
PUBLIC_URL=https://api.cronozen.com

# Google Drive Integration (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.cronozen.com/integrations/google-drive/callback

# App URLs
APP_URL=https://cronozen.com

# File Upload
UPLOAD_DIR=./data/uploads
