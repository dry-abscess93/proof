{
  "name": "cronozen-proof",
  "version": "0.1.0",
  "private": true,
  "description": "Cronozen Proof — Tamper-proof audit trail for AI decisions",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cronozen/proof"
  },
  "workspaces": [
    "packages/*",
    "mcp-server",
    "api-server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace=api-server",
    "dev:mcp": "npm run dev --workspace=mcp-server",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
